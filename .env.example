# Copy to .env and add your key ( .env is gitignored ).
# EIA_API_KEY=

# Local-only: regenerate projects/report-summarizer/fixtures/reports.json (see scripts/generate_report_summaries.py)
# ANTHROPIC_API_KEY=
# Optional: ANTHROPIC_MODEL=claude-sonnet-4-6

# Local-only: run scripts/generate_dicom_study_demo.py to build projects/dicom-study-demo/fixtures/study-analysis.json
# Optional: DICOM_DEMO_MODEL=claude-sonnet-4-6
